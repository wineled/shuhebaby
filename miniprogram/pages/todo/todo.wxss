/* pages/todo/todo.wxss - 粉色版本 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #ffafbd, #ffc3a0);
}

/* 头部样式 */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #ff9e9e;
}

/* 表单区域 */
.form-section {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.form-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #ff6b6b;
  padding-left: 16rpx;
}

.form-item {
  margin-bottom: 30rpx;
  position: relative;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #ff6b6b;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 事务内容文本域 - 增大为原来的2倍 */
.form-textarea {
  border: 2rpx solid #ffd1d1;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  background: #fffafa;
  width: 100%;
  box-sizing: border-box;
  color: #ff6b6b;
  height: 176rpx; /* 增大为原来的2倍（原高度88rpx） */
  line-height: 1.5;
  min-height: 176rpx;
}

.form-textarea:focus {
  border-color: #ff6b6b;
  background: white;
}

.char-count {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  font-size: 24rpx;
  color: #ff9e9e;
}

/* 日期选择器样式 */
.date-picker {
  width: 100%;
}

.picker-display {
  border: 2rpx solid #ffd1d1;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  background: #fffafa;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #ff6b6b;
  height: 88rpx;
  box-sizing: border-box;
}

.picker-display.has-value {
  color: #ff6b6b;
}

.picker-arrow {
  font-size: 24rpx;
  color: #ff9e9e;
}

/* 优先级按钮样式 */
.priority-buttons {
  display: flex;
  gap: 20rpx;
}

.priority-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 20rpx;
  border: 2rpx solid #ffd1d1;
  border-radius: 12rpx;
  background: #fffafa;
  transition: all 0.3s ease;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.priority-btn.active {
  border-width: 3rpx;
  font-weight: bold;
}

.priority-btn.low.active {
  border-color: #27ae60;
  background: rgba(39, 174, 96, 0.1);
}

.priority-btn.medium.active {
  border-color: #f39c12;
  background: rgba(243, 156, 18, 0.1);
}

.priority-btn.high.active {
  border-color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
}

.priority-text {
  font-size: 28rpx;
  color: #ff6b6b;
}

/* 添加按钮 */
.add-button {
  background: #ffd1d1;
  color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 20rpx;
  transition: all 0.3s ease;
  width: 100%;
  border: none;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-button.active {
  background: #ff6b6b;
}

.add-button.active:active {
  background: #ff5252;
  transform: scale(0.98);
}

/* 列表区域 */
.list-section {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.filter-controls {
  display: flex;
  align-items: center;
}

.filter-label {
  font-size: 26rpx;
  color: #ff9e9e;
  margin-right: 16rpx;
}

.filter-picker {
  border: 2rpx solid #ffd1d1;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  background: #fffafa;
}

.filter-display {
  font-size: 26rpx;
  color: #ff6b6b;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 排序控制 */
.sort-controls {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #ffd1d1;
}

.sort-label {
  font-size: 26rpx;
  color: #ff9e9e;
  margin-right: 20rpx;
}

.sort-buttons {
  display: flex;
  gap: 16rpx;
}

.sort-btn {
  padding: 12rpx 20rpx;
  border: 1rpx solid #ffd1d1;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ff9e9e;
  background: #fffafa;
  transition: all 0.3s ease;
}

.sort-btn.active {
  background: #ff6b6b;
  color: white;
  border-color: #ff6b6b;
}

/* 事务项样式 */
.todo-list {
  min-height: 200rpx;
}

.todo-item {
  border: 2rpx solid #ffd1d1;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: flex-start;
  background: #fffafa;
}

.todo-item.completed {
  opacity: 0.7;
  background: #fff5f5;
}

.todo-item.high {
  border-left: 8rpx solid #e74c3c;
}

.todo-item.medium {
  border-left: 8rpx solid #f39c12;
}

.todo-item.low {
  border-left: 8rpx solid #27ae60;
}

.todo-checkbox {
  padding: 24rpx 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ff9e9e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: #27ae60;
  border-color: #27ae60;
}

.todo-content {
  flex: 1;
  padding: 24rpx 24rpx 24rpx 0;
}

.todo-main {
  margin-bottom: 20rpx;
}

.todo-text {
  display: block;
  font-size: 28rpx;
  color: #ff6b6b;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.todo-text.completed {
  text-decoration: line-through;
  color: #ff9e9e;
}

.todo-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.todo-date {
  font-size: 24rpx;
  color: #ff9e9e;
}

.todo-priority {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.todo-priority.high {
  background: #e74c3c;
  color: white;
}

.todo-priority.medium {
  background: #f39c12;
  color: white;
}

.todo-priority.low {
  background: #27ae60;
  color: white;
}

.todo-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.edit-btn {
  background: #ff6b6b;
  color: white;
}

.delete-btn {
  background: #e74c3c;
  color: white;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #ff6b6b;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ff9e9e;
  font-style: italic;
}

/* 统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #ff9e9e;
}