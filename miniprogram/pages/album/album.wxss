.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #ffafbd, #ffc3a0);
}

/* 头部样式 */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #ff9e9e;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  transform: scale(1.05);
}

.tab-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: white;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: 500;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.photo-item {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
  transition: all 0.3s ease;
  position: relative;
}

.photo-item:active {
  transform: scale(0.98);
}

.photo-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.photo-info {
  padding: 20rpx;
}

.photo-date {
  display: block;
  font-size: 22rpx;
  color: #ff9e9e;
  margin-bottom: 8rpx;
}

.photo-desc {
  display: block;
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.photo-actions {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  display: flex;
  gap: 10rpx;
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.action-icon:active {
  transform: scale(0.9);
}

/* 空状态 */
.empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 80rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.empty-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #ff6b6b;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ff9e9e;
  font-style: italic;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.8);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.modal-close {
  font-size: 40rpx;
  color: white;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #ff6b6b;
  margin-bottom: 20rpx;
  text-align: center;
  font-weight: 500;
}

.desc-input {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #ffd1d1;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fffafa;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #ff9e9e;
  margin-top: 10rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #ffd1d1;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cancel-btn {
  color: #ff6b6b;
  border-right: 1rpx solid #ffd1d1;
}

.confirm-btn {
  color: #ff6b6b;
  font-weight: bold;
}

.modal-btn:active {
  background: #fff5f5;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.header,
.category-tabs,
.action-buttons,
.photo-item,
.empty-state {
  animation: fadeIn 0.6s ease-out;
}

.photo-item {
  animation-delay: calc(0.1s * var(--i, 0));
}